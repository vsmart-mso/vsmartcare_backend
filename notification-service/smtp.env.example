# คัดลอกเป็น .env ในโฟลเดอร์นี้ (ไฟล์ .env ถูก gitignore แล้ว)
# จาก service/ รัน: copy notification-service\smtp.env.example notification-service\.env
#
# แล้วแก้ค่าด้านล่าง จากนั้น:
#   docker compose -f docker-compose.yml -f docker-compose.dev.yml up -d notification-service

EMAIL_MODE=smtp
EMAIL_AUTO_SEND=true

# อีเมลผู้รับทดสอบใส่ใน POST /v1/notifications ฟิลด์ "to"
# หรือ UPDATE applicants.email_address แล้วเปลี่ยนสถานะผ่าน staff API

# --- ตัวอย่าง Gmail (ต้องเปิด 2FA + สร้าง App Password) ---
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=your@gmail.com
# SMTP_PASSWORD=xxxx-xxxx-xxxx-xxxx
# SMTP_FROM=your@gmail.com

# --- ตัวอย่าง Microsoft 365 / Outlook ---
# SMTP_HOST=smtp.office365.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false
# SMTP_USER=your@company.onmicrosoft.com
# SMTP_PASSWORD=your-password
# SMTP_FROM=your@company.onmicrosoft.com

# --- relay ภายในองค์กร (ไม่ต้อง auth ก็ปล่อย USER/PASSWORD ว่าง) ---
SMTP_HOST=smtp.your-org.go.th
SMTP_PORT=587
SMTP_USE_TLS=true
SMTP_USE_SSL=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@your-org.go.th
